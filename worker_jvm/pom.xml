<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.redtusk</groupId>
  <artifactId>redtusk-worker</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <properties>
    <maven.compiler.release>25</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <tika.version>4.0.0-SNAPSHOT</tika.version>
    <jackson.version>2.18.3</jackson.version>
    <junit.version>5.11.4</junit.version>
  </properties>

  <dependencies>
    <!-- Tika core API -->
    <dependency>
      <groupId>org.apache.tika</groupId>
      <artifactId>tika-core</artifactId>
      <version>${tika.version}</version>
    </dependency>
    <!-- All standard parsers (Office, PDF, HTML, email, etc.) — POM aggregator -->
    <dependency>
      <groupId>org.apache.tika</groupId>
      <artifactId>tika-parsers-standard-package</artifactId>
      <version>${tika.version}</version>
      <type>pom</type>
    </dependency>
    <!-- Image parser module: native ZXing-CPP barcode scanning + Tika-native OCR -->
    <dependency>
      <groupId>org.apache.tika</groupId>
      <artifactId>tika-parser-image-module</artifactId>
      <version>${tika.version}</version>
    </dependency>
    <!-- JSON serialization -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>${jackson.version}</version>
    </dependency>
    <!-- CRaC API — stub on standard JVM, routes to jdk.crac on Azul Zulu CRaC builds -->
    <dependency>
      <groupId>io.github.crac</groupId>
      <artifactId>org-crac</artifactId>
      <version>0.1.3</version>
    </dependency>
    <!-- Language detection (Optimaize / Lingua: 70+ languages, no models to download) -->
    <dependency>
      <groupId>org.apache.tika</groupId>
      <artifactId>tika-langdetect-optimaize</artifactId>
      <version>${tika.version}</version>
    </dependency>
    <!-- Batik: SVG rasterization for thumbnails. 1.18 carries the fixes for the
         SSRF / external-resource CVEs (CVE-2022-44729 / CVE-2022-44730) and the
         KEY_ALLOW_EXTERNAL_RESOURCES transcoding hint. SVG transcode is further
         locked down with a deny-all UserAgent in EmbeddedFileExtractor. -->
    <dependency>
      <groupId>org.apache.xmlgraphics</groupId>
      <artifactId>batik-transcoder</artifactId>
      <version>1.18</version>
    </dependency>
    <dependency>
      <groupId>org.apache.xmlgraphics</groupId>
      <artifactId>batik-codec</artifactId>
      <version>1.18</version>
    </dependency>
    <!-- AF_VSOCK socket support for the microvm profile's worker↔dispatcher IPC.
         junixsocket-common provides the AF_UNIX API used in tests as a portable
         stand-in; junixsocket-native-common bundles the native shim libs;
         junixsocket-vsock adds AF_VSOCK on top. -->
    <dependency>
      <groupId>com.kohlschutter.junixsocket</groupId>
      <artifactId>junixsocket-common</artifactId>
      <version>2.10.1</version>
    </dependency>
    <dependency>
      <groupId>com.kohlschutter.junixsocket</groupId>
      <artifactId>junixsocket-native-common</artifactId>
      <version>2.10.1</version>
    </dependency>
    <dependency>
      <groupId>com.kohlschutter.junixsocket</groupId>
      <artifactId>junixsocket-vsock</artifactId>
      <version>2.10.1</version>
    </dependency>

    <!-- Testing -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <!-- Compiler configuration -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>25</release>
        </configuration>
      </plugin>
      <!-- Run JUnit 5 tests -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <environmentVariables>
            <REDTUSK_TEST_SCRATCH>${project.build.directory}/test-scratch</REDTUSK_TEST_SCRATCH>
          </environmentVariables>
          <argLine>--enable-native-access=ALL-UNNAMED</argLine>
        </configuration>
      </plugin>
      <!-- Fat JAR for running standalone.
           ServicesResourceTransformer merges all META-INF/services/ files from
           every dependency JAR so Tika's SPI-based parser/detector registries
           (e.g. TXTParser, HtmlParser) are fully populated in the fat JAR. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <configuration>
          <createDependencyReducedPom>false</createDependencyReducedPom>
          <finalName>redtusk-worker</finalName>
          <transformers>
            <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
              <mainClass>io.redtusk.worker.Main</mainClass>
            </transformer>
            <!-- Merge all META-INF/services/* entries from every JAR on the classpath -->
            <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
          </transformers>
          <filters>
            <filter>
              <artifact>*:*</artifact>
              <excludes>
                <exclude>META-INF/*.SF</exclude>
                <exclude>META-INF/*.DSA</exclude>
                <exclude>META-INF/*.RSA</exclude>
              </excludes>
            </filter>
          </filters>
        </configuration>
        <executions>
          <execution>
            <id>make-shaded-jar</id>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
