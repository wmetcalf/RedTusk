# Sample fixtures / corpus — NEVER ship real or synthetic malware/phishing.
# Keep generator scripts here in-repo (under tests/fixtures/) but ignore the
# generated artifacts. Run `python3 tests/fixtures/unicode_qr/generate.py`
# locally to regenerate.
tests/fixtures/**/qr_fixture*
tests/fixtures/**/*.lnk
tests/fixtures/**/*.url
tests/fixtures/**/*.ppkg
tests/fixtures/**/*.msc
tests/fixtures/**/*.rdp
tests/fixtures/**/*.eml
tests/fixtures/**/*.msg
tests/fixtures/**/*.chm
tests/fixtures/**/*.wps
tests/fixtures/**/corpus/

# Per-host runtime config — set REDTUSK_STATE_DIR, POSTGRES_PASSWORD, etc.
# locally; never commit. See deploy/docker/.env.example for the template.
deploy/docker/.env

# corpus-derived bench output — never commit
deploy/firecracker/bench_*.json

# stray tika NER model artifacts (maven dumps these in the wrong place)
/src/test/
