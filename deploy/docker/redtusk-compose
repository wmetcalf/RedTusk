#!/usr/bin/env bash
# Wrapper for `docker compose` that auto-detects the host's docker-socket
# GID (and, with --firecracker, the host's kvm GID) and writes them to
# deploy/docker/.env so the api container's group_add matches. Without
# this, the api (UID 10001) can't read /var/run/docker.sock — and in
# --firecracker mode can't open /dev/kvm — and fails to launch workers.
#
# Usage — same args as `docker compose`, with one optional flag up front:
#   ./deploy/docker/redtusk-compose                up --build -d   # gVisor (default)
#   ./deploy/docker/redtusk-compose --firecracker  up --build -d   # FC microVMs
#   ./deploy/docker/redtusk-compose                logs -f api
#   ./deploy/docker/redtusk-compose                down
#
# --firecracker merges docker-compose.firecracker.yml on top of the base
# file, and pre-flight-checks that the host's FC assets (kernel + rootfs)
# exist — build them once with `scripts/setup_firecracker_host.sh`.
#
# GIDs are detected from the actual device/socket rather than using a
# distro default (which varies per host).
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# ── flag parsing: --firecracker switches in the FC overlay ───────────
FC_MODE=0
COMPOSE_FILES=()
if [ "${1:-}" = "--firecracker" ] || [ "${1:-}" = "--fc" ]; then
    FC_MODE=1
    shift
    COMPOSE_FILES=(-f docker-compose.yml -f docker-compose.firecracker.yml)
fi

DOCKER_SOCK="${DOCKER_SOCK:-/var/run/docker.sock}"
if [ -S "$DOCKER_SOCK" ]; then
    SOCKET_GID="$(stat -c '%g' "$DOCKER_SOCK")"
elif [ -n "${DOCKER_GID:-}" ]; then
    echo "note: $DOCKER_SOCK not found; using DOCKER_GID=$DOCKER_GID from env" >&2
    SOCKET_GID="$DOCKER_GID"
elif [ "$FC_MODE" -eq 1 ]; then
    # FC mode does NOT use the Docker socket: the FC dispatcher spawns microVMs
    # via /dev/kvm, and the docker-socket-proxy is profile-disabled. Don't force
    # the operator to produce a socket/DOCKER_GID it never consumes (matters on
    # rootless/remote-daemon hosts). Write a harmless placeholder so the base
    # compose's ${DOCKER_GID} still substitutes.
    echo "note: --firecracker mode — Docker socket not required; skipping" >&2
    SOCKET_GID=0
else
    echo "error: $DOCKER_SOCK not found and DOCKER_GID env is unset" >&2
    echo "       point DOCKER_SOCK at the real socket or export DOCKER_GID" >&2
    exit 1
fi

touch .env
grep -v '^DOCKER_GID=' .env > .env.tmp || true
mv .env.tmp .env
echo "DOCKER_GID=$SOCKET_GID" >> .env

# ── FC mode: detect KVM_GID from /dev/kvm; check assets exist ────────
if [ "$FC_MODE" -eq 1 ]; then
    if [ ! -c /dev/kvm ]; then
        echo "error: --firecracker requires /dev/kvm on the host" >&2
        echo "       (bare metal or AWS c8i/m8i/r8i with nested virt enabled)" >&2
        exit 1
    fi
    KVM_GID="$(stat -c '%g' /dev/kvm)"
    grep -v '^KVM_GID=' .env > .env.tmp || true
    mv .env.tmp .env
    echo "KVM_GID=$KVM_GID" >> .env

    FC_HOST_DIR="$(grep '^REDTUSK_FC_HOST_DIR=' .env 2>/dev/null | tail -1 | cut -d= -f2-)"
    FC_HOST_DIR="${FC_HOST_DIR:-/var/lib/redtusk/firecracker}"
    case "${1:-}" in
        up|start|restart|run)
            if [ ! -f "$FC_HOST_DIR/vmlinux" ] || [ ! -f "$FC_HOST_DIR/rootfs-vsock.ext4" ]; then
                echo "error: FC assets missing under $FC_HOST_DIR" >&2
                echo "       expected $FC_HOST_DIR/{vmlinux,rootfs-vsock.ext4}" >&2
                echo "       build them once with:" >&2
                echo "         ../../scripts/setup_firecracker_host.sh --with-kernel --state-dir $FC_HOST_DIR" >&2
                echo "       or override the path in .env: REDTUSK_FC_HOST_DIR=/your/path" >&2
                exit 1
            fi
            ;;
    esac
fi

# ── pre-flight: state-dir writability ──────────────────────────────────
# The api container runs as UID 10001 and bind-mounts REDTUSK_STATE_DIR at
# the same path inside the container as on the host. The path must exist
# and be writable by 10001 — otherwise every pool slot fails with
# `[Errno 13] Permission denied` until the queue drains by timeout. The
# usual culprit is the dir being root-owned because it was created with
# sudo during initial host setup. Catch it here before bringing up
# containers so the operator sees one clear error instead of a log
# storm. Skip when the command is anything other than up/start (so
# `down`, `logs`, etc. still work even on a misconfigured host).
case "${1:-}" in
    up|start|restart|run)
        STATE_DIR="$(grep '^REDTUSK_STATE_DIR=' .env | tail -1 | cut -d= -f2-)"
        if [ -z "${STATE_DIR:-}" ]; then
            echo "error: REDTUSK_STATE_DIR is not set in .env" >&2
            echo "       add REDTUSK_STATE_DIR=/path/on/host/for/state to .env" >&2
            exit 1
        fi
        REDTUSK_UID="${REDTUSK_UID:-10001}"
        if [ ! -d "$STATE_DIR" ]; then
            echo "error: REDTUSK_STATE_DIR=$STATE_DIR does not exist on host." >&2
            echo "       Create it and chown to the api container's UID:" >&2
            echo "       sudo mkdir -p $STATE_DIR && sudo chown -R ${REDTUSK_UID}:${REDTUSK_UID} $STATE_DIR" >&2
            exit 1
        fi
        OWNER_UID="$(stat -c '%u' "$STATE_DIR" 2>/dev/null || echo "?")"
        if [ "$OWNER_UID" != "$REDTUSK_UID" ] && [ "$OWNER_UID" != "0" ]; then
            # Owner is neither 10001 nor root — likely a previous bad config.
            # Don't auto-fix; just warn so the operator confirms intent.
            echo "warn: REDTUSK_STATE_DIR=$STATE_DIR is owned by UID $OWNER_UID, expected $REDTUSK_UID" >&2
        fi
        if [ "$OWNER_UID" != "$REDTUSK_UID" ]; then
            # If not owned by the api UID, check it's at least writable
            # (sticky g+w bit, ACL, etc.). Use sudo -n to test as the api
            # uid only if we have passwordless sudo; otherwise rely on
            # a runtime write probe inside the container.
            if [ "$OWNER_UID" = "0" ]; then
                echo "error: REDTUSK_STATE_DIR=$STATE_DIR is owned by root and the api container runs as UID ${REDTUSK_UID}." >&2
                echo "       run:  sudo chown -R ${REDTUSK_UID}:${REDTUSK_UID} $STATE_DIR" >&2
                exit 1
            fi
        fi
        ;;
esac

exec docker compose --project-name redtusk "${COMPOSE_FILES[@]}" "$@"
