# RedTusk Compose configuration — copy to .env and edit.
# RedTusk now runs ON blastbox.host (api = `blastbox serve`, dispatcher =
# `blastbox dispatch`). The redtusk-compose wrapper auto-writes DOCKER_GID
# (and, with --firecracker, KVM_GID); don't set those manually.
#
# IMPORTANT: deploy/docker/.env is PER-HOST and gitignored. Never rsync it to a
# remote host as part of a deploy — overwriting POSTGRES_PASSWORD / REDTUSK_PORT
# / REDTUSK_DATA_DIR with a dev workstation's copy desynchronizes credentials,
# changes the external port, and can break the host-consistent job root.

# ── Postgres (job store + /v1/similar pg_bktree index) ───────────────────────
POSTGRES_DB=redtusk
POSTGRES_USER=redtusk
# REQUIRED — no usable default; compose fails fast if unset. Generate one with:
#   openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_VALUE

# ── Images ───────────────────────────────────────────────────────────────────
# api/dispatcher image (Dockerfile.host). Pin a versioned tag in production.
#   docker build -f deploy/docker/Dockerfile.host -t redtusk:dev .
REDTUSK_IMAGE=redtusk:dev
# Cold WORKER image (Dockerfile.cold-worker, FROM redtusk-worker:default). This
# is what the dispatcher launches per job — NOT redtusk-worker:default (that's a
# bare JVM image; the cold worker runs `python -m blastbox.worker.cold`).
#   docker build -f deploy/docker/Dockerfile.default     -t redtusk-worker:default .
#   docker build -f deploy/docker/Dockerfile.cold-worker -t redtusk-cold-worker:dev .
REDTUSK_WORKER_IMAGE=redtusk-cold-worker:dev

# ── Job root (host-consistent bind path) ─────────────────────────────────────
# The api writes job inputs here; the dispatcher bind-mounts them into workers
# (resolved by the host docker daemon), so it MUST exist at the SAME path on the
# host and in the containers. Owned by UID 10001. Create before first start:
#   sudo mkdir -p "$REDTUSK_DATA_DIR" && sudo chown -R 10001:10001 "$REDTUSK_DATA_DIR"
REDTUSK_DATA_DIR=/var/lib/redtusk

# ── API exposure ─────────────────────────────────────────────────────────────
# The app does NOT authenticate — front with a reverse proxy for any exposed
# deploy. Restrict to localhost with REDTUSK_BIND_ADDR=127.0.0.1.
REDTUSK_PORT=8000
# REDTUSK_BIND_ADDR=0.0.0.0

# ── Dispatcher / worker runtime ──────────────────────────────────────────────
# Empty = auto-detect (prefer runsc/gVisor). Plain runc is fail-closed REFUSED
# unless BLASTBOX_ALLOW_RUNC=1; REQUIRE_SECURE_RUNTIME=1 is a hard never-runc lock.
# BLASTBOX_WORKER_RUNTIME=
# BLASTBOX_ALLOW_RUNC=0
# BLASTBOX_REQUIRE_SECURE_RUNTIME=0
# Concurrency: empty = 1 dispatch loop. Per-job timeout + resource caps (empty =
# auto-size to host).
# BLASTBOX_DISPATCH_CONCURRENCY=
# BLASTBOX_WORKER_TIMEOUT_S=300
# BLASTBOX_WORKER_MEMORY=
# BLASTBOX_WORKER_CPUS=
# BLASTBOX_WORKER_PIDS_LIMIT=
# gVisor warm sidecar aggregate memory ceiling (empty/0 = unbounded). Bounds the
# dispatcher + all warm slots collectively — size for the pool (e.g. 24g), the
# gVisor analogue of BLASTBOX_WORKER_MEMORY (cold) / BLASTBOX_FC_MEM_MIB (FC).
# REDTUSK_GVISOR_MEMORY=
# Job retention (seconds; 0 = keep until explicitly deleted).
# BLASTBOX_JOB_RETENTION_SECONDS=0
# Per-engine forwardable client-param allowlist (default-deny / empty). Per-request
# enable_qr/ocr/thumbnails + recursion limits are a follow-on; leave empty for now.
# BLASTBOX_ENGINE_REDTUSK_PARAM_KEYS=
