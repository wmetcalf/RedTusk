# RedTusk Compose configuration — copy to .env and edit.
# The redtusk-compose wrapper auto-writes DOCKER_GID; don't set it manually.
#
# IMPORTANT: deploy/docker/.env is PER-HOST and gitignored. Never rsync it
# to a remote host as part of a deploy — overwriting POSTGRES_PASSWORD,
# REDTUSK_PORT, or REDTUSK_STATE_DIR with a dev workstation's copy will
# desynchronize Postgres credentials, change the external API port, and
# can trigger state-dir permission failures. Use scripts/deploy_to_host.sh
# which excludes this file by default.

# Postgres credentials
POSTGRES_DB=redtusk
POSTGRES_USER=redtusk
POSTGRES_PASSWORD=change-me-in-production

# Worker image (build with: docker build -f deploy/docker/Dockerfile.default -t redtusk:latest .)
REDTUSK_WORKER_IMAGE=redtusk:latest

# Deployment profile: default | high-density
REDTUSK_PROFILE=default

# Pool sizing:
#   POOL_WARM_SIZE       — slots kept IDLE warm and ready to claim
#   POOL_CONCURRENT_SIZE — hard ceiling on TOTAL in-flight slots (idle+assigned+warming).
#                          Bursting can push current in-flight above warm_size but never
#                          above concurrent_size. Defaults to cpu_count.
#   POOL_BURST_SIZE      — extra slots above warm_size bursting may add.
#
# Legacy: REDTUSK_POOL_SIZE / REDTUSK_POOL_MAX_SIZE still work (aliases for
# the new names). Don't set both old and new — startup fails fast.
REDTUSK_POOL_WARM_SIZE=4
REDTUSK_POOL_CONCURRENT_SIZE=16
REDTUSK_POOL_BURST_SIZE=5

# Optional runc-only host hardening profiles. Leave empty for runsc/gVisor.
# REDTUSK_WORKER_SECCOMP_PROFILE=/absolute/host/path/to/redtusk.seccomp.json
# REDTUSK_WORKER_APPARMOR_PROFILE=redtusk-worker

# External port
REDTUSK_PORT=8000

# Persistent state directory (scratch + artifacts). MUST be set. The path is
# bind-mounted into the API container at the SAME path (so the dispatcher's
# child docker-run bind mounts, which the daemon resolves on the host, see the
# directories the API creates).
#
# The api container runs as UID 10001. The state dir MUST be owned by UID
# 10001 (or otherwise writable by it) or the dispatcher pre-flight will
# refuse to start. Create it before first start:
#   sudo mkdir -p "$REDTUSK_STATE_DIR"
#   sudo chown -R 10001:10001 "$REDTUSK_STATE_DIR"
# REDTUSK_STATE_DIR=/var/lib/redtusk
