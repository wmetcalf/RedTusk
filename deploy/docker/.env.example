# RedTusk Compose configuration — copy to .env and edit.
# The redtusk-compose wrapper auto-writes DOCKER_GID; don't set it manually.
#
# IMPORTANT: deploy/docker/.env is PER-HOST and gitignored. Never rsync it
# to a remote host as part of a deploy — overwriting POSTGRES_PASSWORD,
# REDTUSK_PORT, or REDTUSK_STATE_DIR with a dev workstation's copy will
# desynchronize Postgres credentials, change the external API port, and
# can trigger state-dir permission failures. Use scripts/deploy_to_host.sh
# which excludes this file by default.

# Postgres credentials
POSTGRES_DB=redtusk
POSTGRES_USER=redtusk
# REQUIRED — replace with a strong random value before first start, e.g.:
#   openssl rand -base64 32
# There is NO usable default: docker compose fails fast if this is unset, by
# design. Do not ship the placeholder below to a real deployment.
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_VALUE

# Worker image. Pin to a versioned tag (not :latest) so a re-pull can't swap
# the image under a running deploy. RECOMMENDED: pin by digest in production:
#   REDTUSK_WORKER_IMAGE=redtusk@sha256:<digest>
# Build with: docker build -f deploy/docker/Dockerfile.default -t redtusk:0.1.0 .
REDTUSK_WORKER_IMAGE=redtusk:0.1.0

# Deployment profile: default | high-density
REDTUSK_PROFILE=default

# Pool sizing:
#   POOL_WARM_SIZE       — slots kept IDLE warm and ready to claim
#   POOL_CONCURRENT_SIZE — hard ceiling on TOTAL in-flight slots (idle+assigned+warming).
#                          Bursting can push current in-flight above warm_size but never
#                          above concurrent_size. Defaults to cpu_count.
#   POOL_BURST_SIZE      — extra slots above warm_size bursting may add.
#
# Legacy: REDTUSK_POOL_SIZE / REDTUSK_POOL_MAX_SIZE still work (aliases for
# the new names). Don't set both old and new — startup fails fast.
REDTUSK_POOL_WARM_SIZE=4
REDTUSK_POOL_CONCURRENT_SIZE=16
REDTUSK_POOL_BURST_SIZE=5

# ── API server ──────────────────────────────────────────────────────────────
# Interface the published port binds to. Both are wired through compose but
# default to permissive — set BIND_ADDR=127.0.0.1 to require a reverse proxy
# (strongly recommended in FC mode, where the api process also holds /dev/kvm).
# REDTUSK_BIND_ADDR=0.0.0.0
# Expose the OpenAPI /docs + /redoc + /openapi.json surface. Off by default.
# REDTUSK_EXPOSE_DOCS=false

# Host hardening profiles (runc path). The seccomp profile now DEFAULTS to the
# copy baked into the API image at /opt/redtusk/seccomp/redtusk.seccomp.json —
# you only need to set this to point at a custom profile on the host. gVisor
# (runsc) ignores the seccomp profile and applies its own filter, so the
# default is safe in both runtimes.
# REDTUSK_WORKER_SECCOMP_PROFILE=/absolute/host/path/to/redtusk.seccomp.json
# AppArmor profile name (runc + AppArmor-enabled hosts). Empty = docker-default.
# Load deploy/apparmor/redtusk-worker on the host to use a tighter profile.
# REDTUSK_WORKER_APPARMOR_PROFILE=redtusk-worker

# External port
REDTUSK_PORT=8000

# Persistent state directory (scratch + artifacts). MUST be set. The path is
# bind-mounted into the API container at the SAME path (so the dispatcher's
# child docker-run bind mounts, which the daemon resolves on the host, see the
# directories the API creates).
#
# The api container runs as UID 10001. The state dir MUST be owned by UID
# 10001 (or otherwise writable by it) or the dispatcher pre-flight will
# refuse to start. Create it before first start:
#   sudo mkdir -p "$REDTUSK_STATE_DIR"
#   sudo chown -R 10001:10001 "$REDTUSK_STATE_DIR"
# REDTUSK_STATE_DIR=/var/lib/redtusk

# ── Firecracker microVM workers (optional) ──────────────────────────
# Brought up via: ./deploy/docker/redtusk-compose --firecracker up --build -d
# The wrapper auto-writes KVM_GID; don't set it manually.
#
# Prerequisite — build the FC kernel + rootfs ONCE on the host:
#   scripts/setup_firecracker_host.sh --with-kernel
# (default state dir /var/lib/redtusk/firecracker; override with --state-dir)

# Where the FC kernel + rootfs live on the host. Bind-mounted into the
# api container at the same path (read-only).
# REDTUSK_FC_HOST_DIR=/var/lib/redtusk/firecracker

# Pool sizing for FC — DO NOT oversubscribe: (warm + burst) × fc_vcpu_count ≤ host cores.
# Use the CANONICAL names (set above): the base compose injects only
# REDTUSK_POOL_WARM_SIZE / _CONCURRENT_SIZE / _BURST_SIZE. The legacy
# REDTUSK_POOL_SIZE / _MAX_SIZE aliases are NOT passed into the container, so
# setting them here has NO effect (you'd silently get the warm default and may
# oversubscribe). Recommended for FC:
#   REDTUSK_POOL_WARM_SIZE=$((nproc - 4))   # warm slots
#   REDTUSK_POOL_BURST_SIZE=0
# REDTUSK_FC_VSOCK_RETRIES=2
# Output-disk size. MUST stay ≤ REDTUSK_MAX_EXTRACTED_BYTES + 128 MiB or the
# container fails closed at startup (selftest ConfigurationError, never healthy).
# With the default 500 MiB cap the ceiling is 628 MiB — raise the cap first if you
# raise this. Example (well under the default ceiling):
# REDTUSK_FC_OUTDISK_MIB=600
